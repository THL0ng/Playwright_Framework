{
  "name": "playwright-framework",
  "version": "1.0.0",
  "description": "Playwright Automation Framework",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report:show": "playwright show-report",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "test:staging": "cross-env NODE_ENV=staging BASE_URL=https://staging.app.com playwright test",
    "test:prod": "cross-env NODE_ENV=prod BASE_URL=https://prod.app.com playwright test",
    "test:local": "NODE_ENV=local BASE_URL=http://localhost:8080 playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^25.9.3",
    "allure-playwright": "^3.0.0",
    "cross-env": "^10.1.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "keywords": [
    "playwright",
    "automation",
    "e2e"
  ],
  "author": "YourName"
}